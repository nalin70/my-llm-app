model compliance_matrix_entries {
  id                      BigInt                           @id @default(autoincrement())
  version_id              BigInt
  fund_a_code             String                           @db.VarChar(50)
  fund_b_code             String                           @db.VarChar(50)
  category_a              String?                          @db.VarChar(100)
  category_b              String?                          @db.VarChar(100)
  overlap_limit           Decimal?                         @db.Decimal(6, 4)
  actual_overlap          Decimal                          @db.Decimal(10, 6)
  status                  compliance_matrix_entries_status @default(ALLOWED)
  created_at              DateTime                         @default(now()) @db.DateTime(0)
  overlap_matrix_versions overlap_matrix_versions          @relation(fields: [version_id], references: [id], onDelete: Cascade)

  @@unique([version_id, fund_a_code, fund_b_code], map: "uq_compliance_entry_version_pair")
  @@index([status], map: "idx_compliance_entry_status")
  @@index([version_id], map: "idx_compliance_entry_version")
}

