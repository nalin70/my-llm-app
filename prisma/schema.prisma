generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model all_holdings {
  id                         BigInt    @id @default(autoincrement())
  fund_name                  String?   @db.VarChar(255)
  company_name               String?   @db.VarChar(255)
  group_company_name         String?   @db.VarChar(255)
  sector_name                String?   @db.VarChar(255)
  instrument_name            String?   @db.VarChar(255)
  isin_code                  String?   @db.VarChar(255)
  bse_code                   String?   @db.VarChar(255)
  nse_code                   String?   @db.VarChar(255)
  rating                     String?   @db.VarChar(255)
  rating_agency              String?   @db.VarChar(255)
  quantity                   String?   @db.VarChar(255)
  market_value_crs           String?   @db.VarChar(255)
  percentage_of_net_assets   String?   @db.VarChar(255)
  market_cap                 String?   @db.VarChar(255)
  issuer_name                String?   @db.VarChar(255)
  asset_class_classification String?   @db.VarChar(255)
  mf_name                    String?   @db.VarChar(255)
  adtv                       String?   @db.VarChar(255)
  impact_cost                String?   @db.VarChar(255)
  market_cap_modified        String?   @db.VarChar(255)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @default(now())
  collection_date            DateTime? @db.Date
}

model authentication {
  id                      BigInt                    @id @default(autoincrement())
  email                   String                    @db.VarChar(255)
  password                String                    @db.VarChar(255)
  role                    String?                   @db.VarChar(50)
  name                    String?                   @db.VarChar(255)
  phone                   String?                   @unique(map: "phone") @db.VarChar(20)
  remarks                 String?                   @db.Text
  created_at              DateTime?                 @db.DateTime(0)
  updated_at              DateTime?                 @db.DateTime(0)
  questionnaire_sessions  questionnaire_sessions[]
  soft_optimizer_runs     soft_optimizer_runs[]
  transaction_history     transaction_history[]
  user_optimizer_configs  user_optimizer_configs[]
  user_portfolio_tranches user_portfolio_tranches[]

  @@index([email], map: "authentication_email")
}

model benchmark_nav {
  id                BigInt    @id @default(autoincrement())
  scheme_index_name String?   @db.VarChar(50)
  scheme_code       String?   @db.VarChar(50)
